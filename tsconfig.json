{
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "dist",
    "baseUrl": "src",
    "paths": {
      "@middlewares": ["middlewares/index"],
      "@types": ["types/index"],
      "@models": ["models/index"],
      "@models/*": ["models/*"],
      "@services/*": ["services/*"],
      "@utils": ["utils/index"],
      "@config": ["config/index"],
      "@config/*": ["config/*"],
      "@middlewares/*": ["middlewares/*"],
      "@controllers/*": ["controllers/*"]
    },

    // Environment Settings
    "module": "nodenext",
    "target": "esnext",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    // "exactOptionalPropertyTypes": true,

    // Style Options
    "noImplicitReturns": true,
    // "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    // Recommended Options
    "strict": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
